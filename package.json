{
  "name": "aide",
  "version": "0.0.65",
  "description": "AI Development Environment - Multi-agent orchestration for Claude Code, OpenCode, and Codex CLI",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest --exclude 'dist/**'",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "claude",
    "agents",
    "orchestration",
    "development"
  ],
  "author": "John Mylchreest",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^25.9.0",
    "@types/which": "^3.0.4",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "cross-spawn": "^7.0.6",
    "smol-toml": "^1.6.1",
    "which": "^7.0.0"
  }
}
