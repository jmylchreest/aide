{
  "name": "@jmylchreest/aide-plugin",
  "version": "0.0.58",
  "description": "aide plugin for OpenCode and Codex CLI — multi-agent orchestration, memory, skills, and persistence",
  "type": "module",
  "main": "./src/opencode/index.ts",
  "exports": {
    ".": {
      "import": "./src/opencode/index.ts"
    }
  },
  "files": [
    "src/opencode",
    "src/core",
    "src/cli",
    "src/lib",
    "src/hooks",
    "skills",
    "bin",
    "README.md"
  ],
  "bin": {
    "aide-plugin": "./src/cli/index.ts",
    "aide-wrapper": "./bin/aide-wrapper.ts"
  },
  "scripts": {
    "prebuild": "bun run copy-src",
    "build": "echo 'Ships TypeScript source — no compilation needed'",
    "copy-src": "bun scripts/copy-src.mjs",
    "prepublishOnly": "bun run copy-src"
  },
  "keywords": [
    "aide",
    "opencode",
    "codex",
    "ai",
    "agents",
    "orchestration",
    "plugin",
    "memory",
    "skills"
  ],
  "author": "John Mylchreest",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jmylchreest/aide",
    "directory": "packages/opencode-plugin"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "cross-spawn": "^7.0.6",
    "smol-toml": "^1.3.1",
    "which": "^6.0.1"
  }
}
