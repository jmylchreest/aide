{
  "schema_version": 1,
  "name": "python",
  "version": "0.25.0",
  "c_symbol": "tree_sitter_python",
  "meta": {
    "extensions": [".py", ".pyw", ".pyi"],
    "filenames": [
      "BUILD",
      "BUILD.bazel",
      "WORKSPACE",
      "SConstruct",
      "SConscript"
    ],
    "shebangs": ["python", "python2", "python3"],
    "aliases": ["py"]
  },
  "queries": {
    "tags": "(function_definition name: (identifier) @name) @definition.function\n(class_definition name: (identifier) @name) @definition.class",
    "refs": "(call function: (identifier) @name) @reference.call\n(call function: (attribute attribute: (identifier) @name)) @reference.call\n(type (identifier) @name) @reference.type"
  },
  "complexity": {
    "func_node_types": ["function_definition"],
    "branch_types": [
      "if_statement",
      "elif_clause",
      "for_statement",
      "while_statement",
      "except_clause",
      "with_statement",
      "assert_statement",
      "boolean_operator",
      "conditional_expression",
      "list_comprehension",
      "dictionary_comprehension",
      "set_comprehension",
      "generator_expression"
    ],
    "name_field": "name"
  },
  "imports": {
    "patterns": [
      { "regex": "^\\s*from\\s+(\\S+)\\s+import", "group": 1 },
      { "regex": "^\\s*import\\s+(\\S+)", "group": 1 }
    ]
  },
  "tokenisation": {
    "identifier_types": ["identifier"],
    "literal_types": ["string", "integer", "float", "true", "false", "none"],
    "keyword_types": [
      "if",
      "else",
      "elif",
      "for",
      "while",
      "def",
      "class",
      "import",
      "try",
      "except",
      "finally",
      "raise",
      "return",
      "break",
      "continue",
      "with",
      "yield",
      "lambda",
      "async",
      "await"
    ]
  },
  "entrypoints": {
    "symbols": [
      {
        "name": "__main__",
        "type": "main",
        "label": "Python __main__ module",
        "exclude": "test_|_test\\.py$"
      },
      {
        "name": "main",
        "kind": "function",
        "type": "main",
        "label": "Python main function",
        "exclude": "test_|_test\\.py$"
      },
      {
        "name": "setup",
        "kind": "function",
        "type": "init",
        "label": "Python setup function (setuptools)"
      }
    ],
    "refs": [
      {
        "name": "route",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "Flask/FastAPI route decorator"
      },
      {
        "name": "get",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "HTTP GET handler",
        "qualifier": "app|router|api"
      },
      {
        "name": "post",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "HTTP POST handler",
        "qualifier": "app|router|api"
      },
      {
        "name": "put",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "HTTP PUT handler",
        "qualifier": "app|router|api"
      },
      {
        "name": "delete",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "HTTP DELETE handler",
        "qualifier": "app|router|api"
      },
      {
        "name": "include_router",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "FastAPI router mount"
      },
      {
        "name": "run",
        "ref_kind": "call",
        "type": "server_start",
        "label": "Flask/Uvicorn server start",
        "qualifier": "app|uvicorn"
      },
      {
        "name": "command",
        "ref_kind": "call",
        "type": "cli_root",
        "label": "Click CLI command decorator"
      },
      {
        "name": "group",
        "ref_kind": "call",
        "type": "cli_root",
        "label": "Click CLI group decorator"
      },
      {
        "name": "ArgumentParser",
        "ref_kind": "call",
        "type": "cli_root",
        "label": "argparse CLI setup"
      },
      {
        "name": "add_subparsers",
        "ref_kind": "call",
        "type": "cli_command",
        "label": "argparse subcommand setup"
      }
    ],
    "file_patterns": [
      {
        "file_match": "*.py",
        "content": "if __name__ == [\"']__main__[\"']:",
        "type": "main",
        "label": "Python __main__ guard"
      },
      {
        "file_match": "__main__.py",
        "type": "main",
        "label": "Python package entry point"
      },
      {
        "file_match": "manage.py",
        "type": "main",
        "label": "Django management script"
      },
      {
        "file_match": "wsgi.py",
        "type": "server_start",
        "label": "WSGI application"
      },
      {
        "file_match": "asgi.py",
        "type": "server_start",
        "label": "ASGI application"
      },
      {
        "file_match": "conftest.py",
        "type": "test",
        "label": "Pytest configuration/fixtures"
      }
    ]
  }
}
