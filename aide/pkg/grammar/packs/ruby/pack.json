{
  "schema_version": 1,
  "name": "ruby",
  "version": "",
  "c_symbol": "tree_sitter_ruby",
  "source_repo": "tree-sitter/tree-sitter-ruby",
  "source_tag": "latest",
  "meta": {
    "extensions": [
      ".rb",
      ".rake",
      ".gemspec"
    ],
    "filenames": [
      "Vagrantfile",
      "Rakefile",
      "Gemfile"
    ],
    "shebangs": [
      "ruby"
    ],
    "aliases": [
      "rb"
    ]
  },
  "queries": {
    "tags": "(method name: (identifier) @name) @definition.method\n(singleton_method name: (identifier) @name) @definition.method\n(class name: (constant) @name) @definition.class\n(module name: (constant) @name) @definition.module",
    "refs": "(call method: (identifier) @name) @reference.call\n(constant) @name @reference.type\n(call method: (identifier) @_method (#match? @_method \"^require\") arguments: (argument_list (string (string_content) @name))) @reference.import"
  },
  "complexity": {
    "func_node_types": [
      "method",
      "singleton_method"
    ],
    "branch_types": [
      "if",
      "elsif",
      "unless",
      "while",
      "until",
      "for",
      "when",
      "rescue",
      "binary",
      "conditional"
    ],
    "name_field": "name"
  },
  "imports": {
    "patterns": [
      {
        "regex": "^\\s*require\\s+['\"]([^'\"]+)['\"]",
        "group": 1
      },
      {
        "regex": "^\\s*require_relative\\s+['\"]([^'\"]+)['\"]",
        "group": 1
      },
      {
        "regex": "^\\s*load\\s+['\"]([^'\"]+)['\"]",
        "group": 1
      }
    ]
  },
  "tokenisation": {
    "identifier_types": [
      "identifier",
      "name",
      "constant",
      "symbol"
    ],
    "literal_types": [
      "string_content",
      "heredoc_content",
      "regex"
    ],
    "keyword_types": [
      "module",
      "require",
      "include",
      "rescue",
      "ensure",
      "unless",
      "until",
      "elsif",
      "raise",
      "def",
      "class",
      "end",
      "if",
      "else",
      "while",
      "for",
      "do",
      "begin",
      "return",
      "break",
      "next",
      "yield",
      "block_given?",
      "self",
      "nil",
      "true",
      "false",
      "and",
      "or",
      "not",
      "in",
      "then",
      "when",
      "case",
      "attr_accessor",
      "attr_reader",
      "attr_writer"
    ]
  },
  "entrypoints": {
    "symbols": [
      {
        "name": "configure",
        "kind": "method",
        "type": "init",
        "label": "Ruby configuration block"
      }
    ],
    "refs": [
      {
        "name": "get",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "Sinatra/Rails GET route"
      },
      {
        "name": "post",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "Sinatra/Rails POST route"
      },
      {
        "name": "put",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "Sinatra/Rails PUT route"
      },
      {
        "name": "delete",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "Sinatra/Rails DELETE route"
      },
      {
        "name": "resources",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "Rails resource routes"
      },
      {
        "name": "mount",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "Rails engine mount"
      },
      {
        "name": "run",
        "ref_kind": "call",
        "type": "server_start",
        "label": "Rack/Rails server start"
      },
      {
        "name": "task",
        "ref_kind": "call",
        "type": "task",
        "label": "Rake task definition"
      }
    ],
    "file_patterns": [
      {
        "file_match": "config.ru",
        "type": "server_start",
        "label": "Rack configuration (rackup)"
      },
      {
        "file_match": "config/routes.rb",
        "type": "http_handler",
        "label": "Rails routes configuration"
      },
      {
        "file_match": "config/application.rb",
        "type": "init",
        "label": "Rails application configuration"
      },
      {
        "file_match": "Rakefile",
        "type": "cli_root",
        "label": "Rake task entry point"
      },
      {
        "file_match": "*.rb",
        "content": "^#!/usr/bin/env ruby",
        "type": "cli_root",
        "label": "Ruby executable script"
      }
    ]
  },
  "security": {
    "rules": [
      {
        "id": "ruby-sql-interpolation",
        "name": "Potential SQL injection via string interpolation",
        "severity": "critical",
        "category": "injection",
        "pattern": "(?:where|find_by_sql|execute|select|from|joins|having|order|group)\\s*\\(\\s*\"[^\"]*#\\{",
        "description": "SQL query with string interpolation. Use parameterized queries: where(\"name = ?\", name) or where(name: name)."
      },
      {
        "id": "ruby-eval",
        "name": "Use of eval or send with user input",
        "severity": "critical",
        "category": "injection",
        "pattern": "\\b(?:eval|instance_eval|class_eval|module_eval)\\s*[(\\s]",
        "description": "eval() executes arbitrary Ruby code. Avoid using eval with any user-controlled input."
      },
      {
        "id": "ruby-command-injection",
        "name": "Potential command injection",
        "severity": "warning",
        "category": "exec",
        "pattern": "(?:system|exec|\\`[^`]*\\`|%x\\{)",
        "description": "Shell execution primitive used. Prefer explicit argument lists via Open3, and treat interpolated or user-controlled command construction as critical."
      },
      {
        "id": "ruby-xss",
        "name": "Potential XSS via html_safe or raw",
        "severity": "warning",
        "category": "xss",
        "pattern": "\\.html_safe|\\braw\\s*\\(",
        "description": "html_safe/raw bypasses Rails HTML escaping. Only use on content you have explicitly sanitized."
      },
      {
        "id": "ruby-yaml-unsafe",
        "name": "Unsafe YAML loading",
        "severity": "critical",
        "category": "deserialize",
        "pattern": "YAML\\.load\\s*\\([^)]*(?!safe)",
        "description": "YAML.load can deserialize arbitrary Ruby objects. Use YAML.safe_load or Psych.safe_load instead."
      },
      {
        "id": "ruby-mass-assignment",
        "name": "Potential mass assignment",
        "severity": "warning",
        "category": "injection",
        "pattern": "\\.(?:update_attributes|assign_attributes|new|create)\\s*\\(\\s*params",
        "description": "Mass assignment from params without strong parameters. Use params.require(:model).permit(:field1, :field2)."
      }
    ]
  }
}
