{
  "schema_version": 1,
  "name": "go",
  "version": "0.25.0",
  "c_symbol": "tree_sitter_go",
  "meta": {
    "extensions": [".go"],
    "aliases": ["golang"]
  },
  "queries": {
    "tags": "(function_declaration name: (identifier) @name) @definition.function\n(method_declaration name: (field_identifier) @name) @definition.method\n(type_declaration (type_spec name: (type_identifier) @name type: (struct_type))) @definition.class\n(type_declaration (type_spec name: (type_identifier) @name type: (interface_type))) @definition.interface\n(type_declaration (type_spec name: (type_identifier) @name)) @definition.type",
    "refs": "(call_expression function: (identifier) @name) @reference.call\n(call_expression function: (selector_expression field: (field_identifier) @name)) @reference.call\n(type_identifier) @name @reference.type"
  },
  "complexity": {
    "func_node_types": [
      "function_declaration",
      "method_declaration",
      "func_literal"
    ],
    "branch_types": [
      "if_statement",
      "for_statement",
      "expression_case",
      "type_case",
      "default_case",
      "communication_case",
      "go_statement",
      "defer_statement",
      "binary_expression"
    ],
    "name_field": "name"
  },
  "imports": {
    "patterns": [
      {
        "regex": "^\\s*import\\s+\"([^\"]+)\"",
        "group": 1,
        "context": "single"
      },
      { "regex": "^\\s*\"([^\"]+)\"", "group": 1, "context": "block" }
    ],
    "block_start": "import (",
    "block_end": ")"
  },
  "tokenisation": {
    "identifier_types": [
      "identifier",
      "type_identifier",
      "field_identifier",
      "package_identifier"
    ],
    "literal_types": [
      "interpreted_string_literal",
      "raw_string_literal",
      "int_literal",
      "float_literal"
    ],
    "keyword_types": [
      "func",
      "return",
      "var",
      "const",
      "type",
      "struct",
      "interface",
      "map",
      "chan",
      "go",
      "defer",
      "select",
      "range"
    ]
  },
  "entrypoints": {
    "symbols": [
      {
        "name": "main",
        "kind": "function",
        "type": "main",
        "label": "Go main function",
        "exclude": "_test\\.go$|vendor/|\\.pb\\.go$|_generated\\.go$|_gen\\.go$"
      },
      {
        "name": "init",
        "kind": "function",
        "type": "init",
        "label": "Go init function",
        "exclude": "_test\\.go$|vendor/|\\.pb\\.go$|_generated\\.go$"
      }
    ],
    "refs": [
      {
        "name": "HandleFunc",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "HTTP handler registration"
      },
      {
        "name": "Handle",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "HTTP handler registration",
        "qualifier": "http|mux|router|server"
      },
      {
        "name": "ListenAndServe",
        "ref_kind": "call",
        "type": "server_start",
        "label": "HTTP server start"
      },
      {
        "name": "ListenAndServeTLS",
        "ref_kind": "call",
        "type": "server_start",
        "label": "HTTPS server start"
      },
      {
        "name": "Execute",
        "ref_kind": "call",
        "type": "cli_root",
        "label": "Cobra CLI root execution"
      },
      {
        "name": "ExecuteC",
        "ref_kind": "call",
        "type": "cli_root",
        "label": "Cobra CLI root execution"
      },
      {
        "name": "AddCommand",
        "ref_kind": "call",
        "type": "cli_command",
        "label": "Cobra CLI subcommand registration"
      },
      {
        "name": "Register",
        "ref_kind": "call",
        "type": "grpc_service",
        "label": "gRPC service registration",
        "name_match": "^Register.*Server$"
      },
      {
        "name": "Run",
        "ref_kind": "call",
        "type": "cli_root",
        "label": "urfave/cli app start",
        "qualifier": "App|cli"
      },
      {
        "name": "Serve",
        "ref_kind": "call",
        "type": "server_start",
        "label": "gRPC/net server start",
        "qualifier": "grpc|Server"
      },
      {
        "name": "NewServeMux",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "HTTP multiplexer creation"
      }
    ],
    "file_patterns": [
      {
        "file_match": "*.go",
        "content": "^func main\\(\\)",
        "pre_content": "^package main$",
        "type": "main",
        "label": "Go main function"
      },
      {
        "file_match": "*.go",
        "content": "^func init\\(\\)",
        "type": "init",
        "label": "Go init function"
      }
    ]
  }
}
