{
  "schema_version": 1,
  "name": "go",
  "version": "0.25.0",
  "c_symbol": "tree_sitter_go",
  "meta": {
    "extensions": [
      ".go"
    ],
    "aliases": [
      "golang"
    ]
  },
  "queries": {
    "tags": "(function_declaration name: (identifier) @name) @definition.function\n(method_declaration name: (field_identifier) @name) @definition.method\n(type_declaration (type_spec name: (type_identifier) @name type: (struct_type))) @definition.class\n(type_declaration (type_spec name: (type_identifier) @name type: (interface_type))) @definition.interface\n(type_declaration (type_spec name: (type_identifier) @name)) @definition.type",
    "refs": "(call_expression function: (identifier) @name) @reference.call\n(call_expression function: (selector_expression field: (field_identifier) @name)) @reference.call\n(type_identifier) @name @reference.type\n(import_declaration (import_spec path: (interpreted_string_literal) @name)) @reference.import\n(import_declaration (import_spec_list (import_spec path: (interpreted_string_literal) @name))) @reference.import"
  },
  "complexity": {
    "func_node_types": [
      "function_declaration",
      "method_declaration",
      "func_literal"
    ],
    "branch_types": [
      "if_statement",
      "for_statement",
      "expression_case",
      "type_case",
      "default_case",
      "communication_case",
      "go_statement",
      "defer_statement",
      "binary_expression"
    ],
    "name_field": "name"
  },
  "imports": {
    "patterns": [
      {
        "regex": "^\\s*import\\s+\"([^\"]+)\"",
        "group": 1,
        "context": "single"
      },
      {
        "regex": "^\\s*\"([^\"]+)\"",
        "group": 1,
        "context": "block"
      }
    ],
    "block_start": "import (",
    "block_end": ")"
  },
  "tokenisation": {
    "identifier_types": [
      "identifier",
      "type_identifier",
      "field_identifier",
      "package_identifier"
    ],
    "literal_types": [
      "interpreted_string_literal",
      "raw_string_literal",
      "int_literal",
      "float_literal"
    ],
    "keyword_types": [
      "func",
      "return",
      "var",
      "const",
      "type",
      "struct",
      "interface",
      "map",
      "chan",
      "go",
      "defer",
      "select",
      "range"
    ]
  },
  "entrypoints": {
    "symbols": [
      {
        "name": "main",
        "kind": "function",
        "type": "main",
        "label": "Go main function",
        "exclude": "_test\\.go$|vendor/|\\.pb\\.go$|_generated\\.go$|_gen\\.go$"
      },
      {
        "name": "init",
        "kind": "function",
        "type": "init",
        "label": "Go init function",
        "exclude": "_test\\.go$|vendor/|\\.pb\\.go$|_generated\\.go$"
      }
    ],
    "refs": [
      {
        "name": "HandleFunc",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "HTTP handler registration"
      },
      {
        "name": "Handle",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "HTTP handler registration",
        "qualifier": "http|mux|router|server"
      },
      {
        "name": "ListenAndServe",
        "ref_kind": "call",
        "type": "server_start",
        "label": "HTTP server start"
      },
      {
        "name": "ListenAndServeTLS",
        "ref_kind": "call",
        "type": "server_start",
        "label": "HTTPS server start"
      },
      {
        "name": "Execute",
        "ref_kind": "call",
        "type": "cli_root",
        "label": "Cobra CLI root execution"
      },
      {
        "name": "ExecuteC",
        "ref_kind": "call",
        "type": "cli_root",
        "label": "Cobra CLI root execution"
      },
      {
        "name": "AddCommand",
        "ref_kind": "call",
        "type": "cli_command",
        "label": "Cobra CLI subcommand registration"
      },
      {
        "name": "Register",
        "ref_kind": "call",
        "type": "grpc_service",
        "label": "gRPC service registration",
        "name_match": "^Register.*Server$"
      },
      {
        "name": "Run",
        "ref_kind": "call",
        "type": "cli_root",
        "label": "urfave/cli app start",
        "qualifier": "App|cli"
      },
      {
        "name": "Serve",
        "ref_kind": "call",
        "type": "server_start",
        "label": "gRPC/net server start",
        "qualifier": "grpc|Server"
      },
      {
        "name": "NewServeMux",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "HTTP multiplexer creation"
      }
    ],
    "file_patterns": [
      {
        "file_match": "*.go",
        "content": "^func main\\(\\)",
        "pre_content": "^package main$",
        "type": "main",
        "label": "Go main function"
      },
      {
        "file_match": "*.go",
        "content": "^func init\\(\\)",
        "type": "init",
        "label": "Go init function"
      }
    ]
  },
  "security": {
    "rules": [
      {
        "id": "go-sql-string-concat",
        "name": "Potential SQL injection via string concatenation",
        "severity": "critical",
        "category": "injection",
        "pattern": "(?:Query|Exec|QueryRow|QueryContext|ExecContext|Prepare)\\s*\\([^)]*(?:\\+|fmt\\.Sprintf|fmt\\.Fprintf)",
        "description": "SQL query built with string concatenation or fmt.Sprintf. Use parameterized queries with ? or $1 placeholders instead."
      },
      {
        "id": "go-command-injection",
        "name": "Potential command injection",
        "severity": "warning",
        "category": "exec",
        "pattern": "exec\\.Command\\s*\\(",
        "description": "Process execution primitive used. Prefer exec.CommandContext with explicit argument lists, and treat shell-style invocation or user-controlled command construction as critical."
      },
      {
        "id": "go-command-shell",
        "name": "Shell command via bash -c",
        "severity": "critical",
        "category": "exec",
        "pattern": "exec\\.Command\\s*\\(\\s*(?:\"bash\"|\"sh\"|\"cmd\"|\"powershell\"|\"zsh\")",
        "description": "Shell invocation with subshell. This is highly susceptible to command injection. Pass arguments directly to exec.Command instead."
      },
      {
        "id": "go-path-traversal",
        "name": "Potential path traversal",
        "severity": "warning",
        "category": "traversal",
        "pattern": "filepath\\.Join\\s*\\([^)]*(?:req\\.|r\\.|request\\.|params\\.|query\\.|c\\.)",
        "description": "File path constructed with user input. Validate the resolved path stays within the intended directory using filepath.Rel or filepath.EvalSymlinks."
      },
      {
        "id": "go-weak-crypto-md5",
        "name": "Use of weak hash (MD5)",
        "severity": "warning",
        "category": "crypto",
        "pattern": "md5\\.(?:New|Sum)",
        "description": "MD5 is cryptographically broken. Use sha256 or stronger for integrity checks, and bcrypt/scrypt/argon2 for passwords."
      },
      {
        "id": "go-weak-crypto-sha1",
        "name": "Use of weak hash (SHA1)",
        "severity": "warning",
        "category": "crypto",
        "pattern": "sha1\\.(?:New|Sum)",
        "description": "SHA1 is cryptographically weak. Use sha256 or stronger for integrity checks."
      },
      {
        "id": "go-http-get-user-url",
        "name": "Potential SSRF via user-controlled URL",
        "severity": "warning",
        "category": "ssrf",
        "pattern": "http\\.(?:Get|Post|Head|PostForm)\\s*\\([^)]*(?:req\\.|r\\.|request\\.|params\\.|query\\.|user)",
        "description": "HTTP request with potentially user-controlled URL. Validate the URL scheme and host against an allowlist to prevent SSRF."
      },
      {
        "id": "go-tls-insecure-skip",
        "name": "TLS certificate verification disabled",
        "severity": "critical",
        "category": "crypto",
        "pattern": "InsecureSkipVerify\\s*:\\s*true",
        "description": "TLS certificate verification is disabled, allowing man-in-the-middle attacks. Remove InsecureSkipVerify or set to false."
      },
      {
        "id": "go-unhandled-error",
        "name": "Error discarded with blank identifier",
        "severity": "info",
        "category": "error-handling",
        "pattern": "[^_]\\s*,\\s*_\\s*(?::=|=)\\s*\\w+\\.",
        "description": "Error return value is discarded. Handle errors explicitly to avoid silent failures that may have security implications."
      }
    ]
  },
  "deadcode": {
    "exported_rule": "first_char_uppercase",
    "suppression_patterns": [
      "//\\s*nolint:(?:[a-zA-Z0-9_,-]*\\b)?(?:unused|deadcode|all)\\b",
      "//\\s*aide:keep\\b",
      "//go:linkname\\b",
      "//go:noinline\\b",
      "//\\s*Deprecated:"
    ]
  }
}
