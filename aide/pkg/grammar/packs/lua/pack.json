{
  "schema_version": 1,
  "name": "lua",
  "version": "",
  "c_symbol": "tree_sitter_lua",
  "source_repo": "tree-sitter-grammars/tree-sitter-lua",
  "source_tag": "latest",
  "meta": {
    "extensions": [
      ".lua"
    ],
    "shebangs": [
      "lua"
    ]
  },
  "queries": {
    "tags": "(function_declaration name: (identifier) @name) @definition.function\n(function_declaration name: (dot_index_expression field: (identifier) @name)) @definition.method\n(assignment_statement (variable_list name: (identifier) @name) (expression_list value: (function_definition))) @definition.function"
  },
  "complexity": {
    "func_node_types": [
      "function_declaration",
      "local_function_declaration_statement",
      "function_definition"
    ],
    "branch_types": [
      "if_statement",
      "elseif_clause",
      "for_statement",
      "for_generic_statement",
      "while_statement",
      "repeat_statement",
      "binary_expression"
    ],
    "name_field": "name"
  },
  "imports": {
    "patterns": [
      {
        "regex": "require\\s*\\(?\\s*['\"]([^'\"]+)['\"]",
        "group": 1
      },
      {
        "regex": "dofile\\s*\\(\\s*['\"]([^'\"]+)['\"]",
        "group": 1
      }
    ]
  },
  "tokenisation": {
    "identifier_types": [
      "identifier"
    ],
    "literal_types": [
      "string",
      "number"
    ],
    "keyword_types": [
      "require",
      "function",
      "local",
      "if",
      "then",
      "else",
      "elseif",
      "end",
      "for",
      "while",
      "do",
      "repeat",
      "until",
      "return",
      "break",
      "not",
      "and",
      "or",
      "in",
      "nil",
      "true",
      "false"
    ]
  },
  "entrypoints": {
    "symbols": [
      {
        "name": "main",
        "kind": "function",
        "type": "main",
        "label": "Lua main function"
      },
      {
        "name": "setup",
        "kind": "function",
        "type": "init",
        "label": "Lua setup function (Neovim plugins)"
      },
      {
        "name": "config",
        "kind": "function",
        "type": "init",
        "label": "Lua config function (Neovim plugins)"
      }
    ],
    "file_patterns": [
      {
        "file_match": "init.lua",
        "type": "module_entry",
        "label": "Lua module entry point"
      },
      {
        "file_match": "main.lua",
        "type": "main",
        "label": "Lua main script"
      },
      {
        "file_match": "*.lua",
        "content": "^#!/usr/bin/env lua",
        "type": "main",
        "label": "Lua executable script"
      }
    ]
  },
  "deadcode": {
    "exported_rule": "no_leading_underscore",
    "suppression_patterns": [
      "--\\s*luacheck:\\s*ignore\\b",
      "--\\s*aide:keep\\b"
    ],
    "test_file_patterns": [
      "**/*_spec.lua",
      "**/*_test.lua",
      "**/spec/**/*.lua",
      "**/tests/**/*.lua"
    ],
    "framework_hook_names": [
      "setup",
      "teardown",
      "before_each",
      "after_each",
      "describe",
      "it"
    ]
  },
  "comments": {
    "line": [
      "--"
    ],
    "block": [
      [
        "--[[",
        "]]"
      ]
    ]
  }
}
