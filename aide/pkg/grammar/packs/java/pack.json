{
  "schema_version": 1,
  "name": "java",
  "version": "0.23.5",
  "c_symbol": "tree_sitter_java",
  "meta": {
    "extensions": [
      ".java"
    ]
  },
  "queries": {
    "tags": "(method_declaration name: (identifier) @name) @definition.method\n(constructor_declaration name: (identifier) @name) @definition.method\n(class_declaration name: (identifier) @name) @definition.class\n(interface_declaration name: (identifier) @name) @definition.interface\n(enum_declaration name: (identifier) @name) @definition.class",
    "refs": "(method_invocation name: (identifier) @name) @reference.call\n(object_creation_expression type: (type_identifier) @name) @reference.call\n(type_identifier) @name @reference.type\n(import_declaration (scoped_identifier) @name) @reference.import"
  },
  "complexity": {
    "func_node_types": [
      "method_declaration",
      "constructor_declaration"
    ],
    "branch_types": [
      "if_statement",
      "for_statement",
      "enhanced_for_statement",
      "while_statement",
      "do_statement",
      "switch_block_statement_group",
      "catch_clause",
      "ternary_expression",
      "binary_expression"
    ],
    "name_field": "name"
  },
  "imports": {
    "patterns": [
      {
        "regex": "^\\s*import\\s+(?:static\\s+)?([a-zA-Z0-9_.]+)",
        "group": 1
      }
    ]
  },
  "tokenisation": {
    "identifier_types": [
      "identifier",
      "type_identifier"
    ],
    "literal_types": [
      "string_literal",
      "character_literal",
      "decimal_integer_literal",
      "hex_integer_literal",
      "decimal_floating_point_literal",
      "true",
      "false",
      "null"
    ],
    "keyword_types": [
      "if",
      "else",
      "for",
      "while",
      "switch",
      "case",
      "return",
      "break",
      "continue",
      "class",
      "interface",
      "import",
      "try",
      "catch",
      "finally",
      "throw",
      "do",
      "enum"
    ]
  },
  "entrypoints": {
    "symbols": [
      {
        "name": "main",
        "kind": "method",
        "type": "main",
        "label": "Java main method",
        "exclude": "test/|Test\\.java$"
      }
    ],
    "refs": [
      {
        "name": "run",
        "ref_kind": "call",
        "type": "server_start",
        "label": "Spring Boot application start",
        "qualifier": "SpringApplication"
      },
      {
        "name": "addServlet",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "Servlet registration"
      },
      {
        "name": "addService",
        "ref_kind": "call",
        "type": "grpc_service",
        "label": "gRPC service registration"
      },
      {
        "name": "bindService",
        "ref_kind": "call",
        "type": "grpc_service",
        "label": "gRPC service binding"
      }
    ],
    "file_patterns": [
      {
        "file_match": "*.java",
        "content": "public static void main\\(String",
        "type": "main",
        "label": "Java main method"
      },
      {
        "file_match": "*.java",
        "content": "@SpringBootApplication",
        "type": "server_start",
        "label": "Spring Boot application"
      }
    ]
  },
  "security": {
    "rules": [
      {
        "id": "java-sql-string-concat",
        "name": "Potential SQL injection via string concatenation",
        "severity": "critical",
        "category": "injection",
        "pattern": "(?:executeQuery|executeUpdate|prepareStatement|execute)\\s*\\([^)]*(?:\\+|String\\.format)",
        "description": "SQL query built with string concatenation. Use PreparedStatement with ? placeholders."
      },
      {
        "id": "java-command-injection",
        "name": "Potential command injection",
        "severity": "warning",
        "category": "exec",
        "pattern": "Runtime\\.getRuntime\\(\\)\\.exec\\s*\\(",
        "description": "Process execution primitive used. Prefer ProcessBuilder with explicit arguments, and treat shell-style invocation or user-controlled command construction as critical."
      },
      {
        "id": "java-deserialization",
        "name": "Unsafe Java deserialization",
        "severity": "critical",
        "category": "deserialize",
        "pattern": "ObjectInputStream\\s*\\(",
        "description": "Java deserialization can execute arbitrary code. Use look-ahead deserialization or switch to JSON/protobuf."
      },
      {
        "id": "java-xxe",
        "name": "Potential XXE vulnerability",
        "severity": "critical",
        "category": "injection",
        "pattern": "(?:SAXParserFactory|DocumentBuilderFactory|XMLInputFactory)\\.newInstance\\s*\\(",
        "description": "XML parser may be vulnerable to XXE attacks. Disable external entities: setFeature(\"http://apache.org/xml/features/disallow-doctype-decl\", true)."
      },
      {
        "id": "java-weak-hash",
        "name": "Use of weak hash function",
        "severity": "warning",
        "category": "crypto",
        "pattern": "MessageDigest\\.getInstance\\s*\\(\\s*\"(?:MD5|SHA-1|SHA1)\"",
        "description": "MD5/SHA1 are cryptographically weak. Use SHA-256 or stronger. For passwords, use BCrypt or Argon2."
      },
      {
        "id": "java-path-traversal",
        "name": "Potential path traversal",
        "severity": "warning",
        "category": "traversal",
        "pattern": "new\\s+File\\s*\\([^)]*(?:request\\.|getParameter|getHeader|getPathInfo)",
        "description": "File path from user input. Canonicalize and validate against allowed directories."
      },
      {
        "id": "java-xss",
        "name": "Potential XSS via unescaped output",
        "severity": "warning",
        "category": "xss",
        "pattern": "(?:getWriter\\(\\)|getOutputStream\\(\\))\\.(?:print|write)\\s*\\([^)]*(?:request\\.|getParameter)",
        "description": "User input written directly to response. Escape HTML output or use a templating engine with auto-escaping."
      },
      {
        "id": "java-insecure-random",
        "name": "Use of java.util.Random for security",
        "severity": "warning",
        "category": "crypto",
        "pattern": "new\\s+Random\\s*\\(",
        "description": "java.util.Random is not cryptographically secure. Use java.security.SecureRandom for tokens and security-sensitive values."
      }
    ]
  },
  "deadcode": {
    "suppression_patterns": [
      "@SuppressWarnings\\s*\\([^)]*\\bunused\\b",
      "//\\s*noinspection\\b.*\\bunused\\b",
      "//\\s*aide:keep\\b",
      "@Deprecated\\b"
    ],
    "test_file_patterns": [
      "**/src/test/**/*.java",
      "**/*Test.java",
      "**/*Tests.java",
      "**/*TestCase.java"
    ],
    "test_function_prefixes": [],
    "framework_hook_names": []
  },
  "notes": "Modern JUnit (4/5) and TestNG are annotation-driven (`@Test`, `@BeforeAll`, etc.); test method names are arbitrary so no name-based test prefix or hook list is encoded. Skip relies on file patterns alone."
}
