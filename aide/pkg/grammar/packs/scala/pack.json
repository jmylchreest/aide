{
  "schema_version": 1,
  "name": "scala",
  "version": "",
  "c_symbol": "tree_sitter_scala",
  "source_repo": "tree-sitter/tree-sitter-scala",
  "source_tag": "latest",
  "meta": {
    "extensions": [".scala", ".sc"],
    "shebangs": ["scala"]
  },
  "queries": {
    "tags": "(function_definition name: (identifier) @name) @definition.function\n(class_definition name: (identifier) @name) @definition.class\n(object_definition name: (identifier) @name) @definition.class\n(trait_definition name: (identifier) @name) @definition.interface"
  },
  "complexity": {
    "func_node_types": ["function_definition"],
    "branch_types": [
      "if_expression",
      "for_expression",
      "while_expression",
      "case_clause",
      "catch_clause",
      "binary_expression"
    ],
    "name_field": "name"
  },
  "imports": {
    "patterns": [
      {
        "regex": "^\\s*import\\s+([a-zA-Z0-9_.{}]+)",
        "group": 1
      }
    ]
  },
  "tokenisation": {
    "identifier_types": ["identifier"],
    "literal_types": [
      "boolean_literal",
      "integer_literal",
      "floating_point_literal",
      "string",
      "character_literal",
      "symbol_literal",
      "null_literal"
    ],
    "keyword_types": [
      "match",
      "val",
      "trait",
      "def",
      "class",
      "object",
      "extends",
      "with",
      "import",
      "package",
      "if",
      "else",
      "for",
      "while",
      "do",
      "return",
      "try",
      "catch",
      "finally",
      "throw",
      "new",
      "case",
      "yield",
      "type",
      "abstract",
      "override",
      "final",
      "lazy",
      "sealed",
      "implicit",
      "null",
      "true",
      "false",
      "this",
      "super"
    ]
  },
  "entrypoints": {
    "symbols": [
      {
        "name": "main",
        "kind": "function",
        "type": "main",
        "label": "Scala main method"
      }
    ],
    "file_patterns": [
      {
        "file_match": "*.scala",
        "content": "def main\\(args:\\s*Array\\[String\\]\\)",
        "type": "main",
        "label": "Scala main method"
      },
      {
        "file_match": "*.scala",
        "content": "extends App\\b",
        "type": "main",
        "label": "Scala App trait entry point"
      },
      {
        "file_match": "*.scala",
        "content": "@main\\b",
        "type": "main",
        "label": "Scala 3 @main annotation"
      }
    ]
  },
  "deadcode": {
    "suppression_patterns": [
      "@unused\\b",
      "@nowarn\\b",
      "//\\s*aide:keep\\b",
      "@deprecated\\b"
    ]
  }
}
