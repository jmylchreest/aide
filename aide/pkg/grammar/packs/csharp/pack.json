{
  "schema_version": 1,
  "name": "csharp",
  "version": "",
  "c_symbol": "tree_sitter_c_sharp",
  "source_repo": "tree-sitter/tree-sitter-c-sharp",
  "source_tag": "v0.23.1",
  "meta": {
    "extensions": [".cs"],
    "aliases": ["c#", "cs"]
  },
  "queries": {
    "tags": "(method_declaration name: (identifier) @name) @definition.method\n(constructor_declaration name: (identifier) @name) @definition.method\n(class_declaration name: (identifier) @name) @definition.class\n(interface_declaration name: (identifier) @name) @definition.interface\n(struct_declaration name: (identifier) @name) @definition.class\n(enum_declaration name: (identifier) @name) @definition.class"
  },
  "complexity": {
    "func_node_types": [
      "method_declaration",
      "constructor_declaration",
      "local_function_statement"
    ],
    "branch_types": [
      "if_statement",
      "for_statement",
      "for_each_statement",
      "while_statement",
      "do_statement",
      "switch_section",
      "catch_clause",
      "conditional_expression",
      "binary_expression"
    ],
    "name_field": "name"
  },
  "imports": {
    "patterns": [
      {
        "regex": "^\\s*using\\s+(?:static\\s+)?([a-zA-Z0-9_.]+)",
        "group": 1
      }
    ]
  },
  "tokenisation": {
    "identifier_types": ["identifier"],
    "literal_types": [
      "integer_literal",
      "real_literal",
      "string_literal",
      "verbatim_string_literal",
      "character_literal",
      "boolean_literal",
      "null_literal"
    ],
    "keyword_types": [
      "if",
      "else",
      "for",
      "foreach",
      "while",
      "do",
      "switch",
      "case",
      "break",
      "continue",
      "return",
      "class",
      "struct",
      "interface",
      "enum",
      "namespace",
      "using",
      "try",
      "catch",
      "finally",
      "throw",
      "new",
      "async",
      "await",
      "var",
      "void"
    ]
  },
  "entrypoints": {
    "symbols": [
      {
        "name": "Main",
        "kind": "method",
        "type": "main",
        "label": "C# Main method",
        "exclude": "Test|test"
      },
      {
        "name": "ConfigureServices",
        "kind": "method",
        "type": "init",
        "label": "ASP.NET service configuration"
      },
      {
        "name": "Configure",
        "kind": "method",
        "type": "init",
        "label": "ASP.NET middleware configuration"
      }
    ],
    "file_patterns": [
      {
        "file_match": "Program.cs",
        "type": "main",
        "label": "C# program entry point"
      },
      {
        "file_match": "Startup.cs",
        "type": "init",
        "label": "ASP.NET Startup class"
      },
      {
        "file_match": "*.cs",
        "content": "static void Main\\(",
        "type": "main",
        "label": "C# Main method"
      },
      {
        "file_match": "*.cs",
        "content": "static async Task Main\\(",
        "type": "main",
        "label": "C# async Main method"
      },
      {
        "file_match": "*.cs",
        "content": "\\[ApiController\\]",
        "type": "http_handler",
        "label": "ASP.NET API controller"
      },
      {
        "file_match": "*.cs",
        "content": "WebApplication\\.Create",
        "type": "server_start",
        "label": "ASP.NET minimal API"
      },
      {
        "file_match": "*.cs",
        "content": "Host\\.CreateDefaultBuilder",
        "type": "server_start",
        "label": "ASP.NET host builder"
      }
    ]
  }
}
