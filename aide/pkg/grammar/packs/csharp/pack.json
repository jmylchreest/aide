{
  "schema_version": 1,
  "name": "csharp",
  "version": "",
  "c_symbol": "tree_sitter_c_sharp",
  "source_repo": "tree-sitter/tree-sitter-c-sharp",
  "source_tag": "latest",
  "meta": {
    "extensions": [
      ".cs"
    ],
    "aliases": [
      "c#",
      "cs"
    ]
  },
  "queries": {
    "tags": "(method_declaration name: (identifier) @name) @definition.method\n(constructor_declaration name: (identifier) @name) @definition.method\n(class_declaration name: (identifier) @name) @definition.class\n(interface_declaration name: (identifier) @name) @definition.interface\n(struct_declaration name: (identifier) @name) @definition.class\n(enum_declaration name: (identifier) @name) @definition.class",
    "refs": "(using_directive (qualified_name) @name) @reference.import"
  },
  "complexity": {
    "func_node_types": [
      "method_declaration",
      "constructor_declaration",
      "local_function_statement"
    ],
    "branch_types": [
      "if_statement",
      "for_statement",
      "for_each_statement",
      "while_statement",
      "do_statement",
      "switch_section",
      "catch_clause",
      "conditional_expression",
      "binary_expression"
    ],
    "name_field": "name"
  },
  "imports": {
    "patterns": [
      {
        "regex": "^\\s*using\\s+(?:static\\s+)?([a-zA-Z0-9_.]+)",
        "group": 1
      }
    ]
  },
  "tokenisation": {
    "identifier_types": [
      "identifier"
    ],
    "literal_types": [
      "integer_literal",
      "real_literal",
      "string_literal",
      "verbatim_string_literal",
      "character_literal",
      "boolean_literal",
      "null_literal"
    ],
    "keyword_types": [
      "if",
      "else",
      "for",
      "foreach",
      "while",
      "do",
      "switch",
      "case",
      "break",
      "continue",
      "return",
      "class",
      "struct",
      "interface",
      "enum",
      "namespace",
      "using",
      "try",
      "catch",
      "finally",
      "throw",
      "new",
      "async",
      "await",
      "var",
      "void"
    ]
  },
  "entrypoints": {
    "symbols": [
      {
        "name": "Main",
        "kind": "method",
        "type": "main",
        "label": "C# Main method",
        "exclude": "Test|test"
      },
      {
        "name": "ConfigureServices",
        "kind": "method",
        "type": "init",
        "label": "ASP.NET service configuration"
      },
      {
        "name": "Configure",
        "kind": "method",
        "type": "init",
        "label": "ASP.NET middleware configuration"
      }
    ],
    "file_patterns": [
      {
        "file_match": "Program.cs",
        "type": "main",
        "label": "C# program entry point"
      },
      {
        "file_match": "Startup.cs",
        "type": "init",
        "label": "ASP.NET Startup class"
      },
      {
        "file_match": "*.cs",
        "content": "static void Main\\(",
        "type": "main",
        "label": "C# Main method"
      },
      {
        "file_match": "*.cs",
        "content": "static async Task Main\\(",
        "type": "main",
        "label": "C# async Main method"
      },
      {
        "file_match": "*.cs",
        "content": "\\[ApiController\\]",
        "type": "http_handler",
        "label": "ASP.NET API controller"
      },
      {
        "file_match": "*.cs",
        "content": "WebApplication\\.Create",
        "type": "server_start",
        "label": "ASP.NET minimal API"
      },
      {
        "file_match": "*.cs",
        "content": "Host\\.CreateDefaultBuilder",
        "type": "server_start",
        "label": "ASP.NET host builder"
      }
    ]
  },
  "security": {
    "rules": [
      {
        "id": "cs-sql-string-concat",
        "name": "Potential SQL injection via string concatenation",
        "severity": "critical",
        "category": "injection",
        "pattern": "(?:ExecuteNonQuery|ExecuteReader|ExecuteScalar|SqlCommand)\\s*\\([^)]*(?:\\+|\\$\")",
        "description": "SQL query built with string concatenation. Use SqlParameter with parameterized queries."
      },
      {
        "id": "cs-command-injection",
        "name": "Potential command injection",
        "severity": "warning",
        "category": "exec",
        "pattern": "Process\\.Start\\s*\\(",
        "description": "Process execution primitive used. Prefer ProcessStartInfo with UseShellExecute=false and explicit arguments, and treat shell-style invocation or user-controlled command construction as critical."
      },
      {
        "id": "cs-xss",
        "name": "Potential XSS via Html.Raw",
        "severity": "warning",
        "category": "xss",
        "pattern": "Html\\.Raw\\s*\\(",
        "description": "Html.Raw() bypasses HTML encoding. Only use on content you have explicitly sanitized."
      },
      {
        "id": "cs-deserialization",
        "name": "Unsafe deserialization",
        "severity": "critical",
        "category": "deserialize",
        "pattern": "(?:BinaryFormatter|SoapFormatter|NetDataContractSerializer|ObjectStateFormatter)\\.Deserialize\\s*\\(",
        "description": "BinaryFormatter deserialization enables arbitrary code execution. Use System.Text.Json or DataContractSerializer."
      },
      {
        "id": "cs-xxe",
        "name": "Potential XXE vulnerability",
        "severity": "critical",
        "category": "injection",
        "pattern": "XmlReader\\.Create\\s*\\(",
        "description": "XML parsing may be vulnerable to XXE. Use XmlReaderSettings with DtdProcessing = DtdProcessing.Prohibit."
      },
      {
        "id": "cs-path-traversal",
        "name": "Potential path traversal",
        "severity": "warning",
        "category": "traversal",
        "pattern": "Path\\.Combine\\s*\\([^)]*(?:Request|HttpContext|user|input)",
        "description": "File path from user input. Canonicalize with Path.GetFullPath() and validate against allowed directories."
      }
    ]
  },
  "deadcode": {
    "suppression_patterns": [
      "\\[SuppressMessage\\b",
      "//\\s*aide:keep\\b",
      "\\[Obsolete\\b"
    ]
  }
}
