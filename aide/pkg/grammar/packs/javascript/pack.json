{
  "schema_version": 1,
  "name": "javascript",
  "version": "0.25.0",
  "c_symbol": "tree_sitter_javascript",
  "meta": {
    "extensions": [".js", ".jsx", ".mjs", ".cjs"],
    "shebangs": ["node"],
    "aliases": ["js", "jsx"]
  },
  "queries": {
    "tags": "(function_declaration name: (identifier) @name) @definition.function\n(method_definition name: (property_identifier) @name) @definition.method\n(class_declaration name: (identifier) @name) @definition.class",
    "refs": "(call_expression function: (identifier) @name) @reference.call\n(call_expression function: (member_expression property: (property_identifier) @name)) @reference.call\n(new_expression constructor: (identifier) @name) @reference.call"
  },
  "complexity": {
    "func_node_types": [
      "function_declaration",
      "method_definition",
      "arrow_function",
      "function"
    ],
    "branch_types": [
      "if_statement",
      "for_statement",
      "for_in_statement",
      "while_statement",
      "do_statement",
      "switch_case",
      "catch_clause",
      "ternary_expression",
      "binary_expression"
    ],
    "name_field": "name"
  },
  "imports": {
    "patterns": [
      {
        "regex": "(?:import|export)\\s+.*from\\s+['\"]([^'\"]+)['\"]",
        "group": 1
      },
      { "regex": "require\\s*\\(\\s*['\"]([^'\"]+)['\"]", "group": 1 }
    ]
  },
  "tokenisation": {
    "identifier_types": [
      "identifier",
      "property_identifier",
      "shorthand_property_identifier",
      "shorthand_property_identifier_pattern"
    ],
    "literal_types": [
      "string",
      "template_string",
      "number",
      "true",
      "false",
      "null",
      "undefined"
    ],
    "keyword_types": [
      "if",
      "else",
      "for",
      "while",
      "switch",
      "case",
      "return",
      "break",
      "continue",
      "function",
      "class",
      "import",
      "try",
      "catch",
      "finally",
      "throw",
      "async",
      "await",
      "let",
      "var",
      "const",
      "do",
      "yield"
    ]
  },
  "entrypoints": {
    "symbols": [
      {
        "name": "main",
        "kind": "function",
        "type": "main",
        "label": "JavaScript main function"
      }
    ],
    "refs": [
      {
        "name": "get",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "Express GET handler",
        "qualifier": "app|router"
      },
      {
        "name": "post",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "Express POST handler",
        "qualifier": "app|router"
      },
      {
        "name": "put",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "Express PUT handler",
        "qualifier": "app|router"
      },
      {
        "name": "delete",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "Express DELETE handler",
        "qualifier": "app|router"
      },
      {
        "name": "use",
        "ref_kind": "call",
        "type": "middleware",
        "label": "Express middleware registration",
        "qualifier": "app|router"
      },
      {
        "name": "listen",
        "ref_kind": "call",
        "type": "server_start",
        "label": "HTTP server listen",
        "qualifier": "app|server|http"
      },
      {
        "name": "createServer",
        "ref_kind": "call",
        "type": "server_start",
        "label": "HTTP server creation"
      },
      {
        "name": "register",
        "ref_kind": "call",
        "type": "plugin",
        "label": "Fastify plugin registration",
        "qualifier": "fastify|server"
      },
      {
        "name": "command",
        "ref_kind": "call",
        "type": "cli_root",
        "label": "Commander.js CLI command"
      },
      {
        "name": "parse",
        "ref_kind": "call",
        "type": "cli_root",
        "label": "Commander.js CLI parse",
        "qualifier": "program|commander"
      },
      {
        "name": "yargs",
        "ref_kind": "call",
        "type": "cli_root",
        "label": "Yargs CLI setup"
      }
    ],
    "file_patterns": [
      {
        "file_match": "index.js",
        "type": "module_entry",
        "label": "JavaScript module entry point"
      },
      {
        "file_match": "index.mjs",
        "type": "module_entry",
        "label": "JavaScript ES module entry point"
      },
      {
        "file_match": "server.js",
        "type": "server_start",
        "label": "JavaScript server entry point"
      },
      {
        "file_match": "app.js",
        "type": "server_start",
        "label": "JavaScript application entry point"
      },
      {
        "file_match": "cli.js",
        "type": "cli_root",
        "label": "JavaScript CLI entry point"
      },
      {
        "file_match": "*.js",
        "content": "^#!/usr/bin/env node",
        "type": "cli_root",
        "label": "Node.js executable script"
      }
    ]
  }
}
