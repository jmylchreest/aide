{
  "schema_version": 1,
  "name": "swift",
  "version": "",
  "c_symbol": "tree_sitter_swift",
  "source_repo": "alex-pinkus/tree-sitter-swift",
  "source_tag": "latest",
  "meta": {
    "extensions": [".swift"],
    "shebangs": ["swift"]
  },
  "queries": {
    "tags": "(function_declaration name: (simple_identifier) @name) @definition.function\n(class_declaration name: (type_identifier) @name) @definition.class\n(struct_declaration name: (type_identifier) @name) @definition.class\n(protocol_declaration name: (type_identifier) @name) @definition.interface\n(enum_declaration name: (type_identifier) @name) @definition.class"
  },
  "complexity": {
    "func_node_types": ["function_declaration"],
    "branch_types": [
      "if_statement",
      "for_statement",
      "while_statement",
      "repeat_while_statement",
      "switch_case",
      "catch_clause",
      "guard_statement",
      "ternary_expression",
      "binary_expression"
    ],
    "name_field": "name"
  },
  "imports": {
    "patterns": [
      {
        "regex": "^\\s*import\\s+(?:class\\s+|struct\\s+|enum\\s+|protocol\\s+|func\\s+)?([a-zA-Z0-9_.]+)",
        "group": 1
      }
    ]
  },
  "tokenisation": {
    "identifier_types": ["simple_identifier", "type_identifier"],
    "literal_types": [
      "integer_literal",
      "multi_line_string_literal",
      "boolean_literal"
    ],
    "keyword_types": [
      "guard",
      "let",
      "var",
      "func",
      "class",
      "struct",
      "protocol",
      "enum",
      "extension",
      "if",
      "else",
      "for",
      "while",
      "repeat",
      "switch",
      "case",
      "break",
      "continue",
      "return",
      "try",
      "catch",
      "throw",
      "import",
      "self",
      "super",
      "nil",
      "true",
      "false",
      "init",
      "deinit",
      "override",
      "static",
      "private",
      "public",
      "internal",
      "fileprivate",
      "open",
      "async",
      "await"
    ]
  },
  "entrypoints": {
    "symbols": [
      {
        "name": "main",
        "kind": "function",
        "type": "main",
        "label": "Swift main function"
      }
    ],
    "file_patterns": [
      {
        "file_match": "main.swift",
        "type": "main",
        "label": "Swift main entry point (convention)"
      },
      {
        "file_match": "*.swift",
        "content": "@main",
        "type": "main",
        "label": "Swift @main attribute entry point"
      },
      {
        "file_match": "*.swift",
        "content": "@UIApplicationMain",
        "type": "ui_root",
        "label": "iOS UIKit app delegate entry point"
      },
      {
        "file_match": "*.swift",
        "content": "WindowGroup",
        "type": "ui_root",
        "label": "SwiftUI app entry point"
      },
      {
        "file_match": "AppDelegate.swift",
        "type": "ui_root",
        "label": "iOS/macOS app delegate"
      },
      {
        "file_match": "ContentView.swift",
        "type": "ui_root",
        "label": "SwiftUI root view"
      }
    ]
  }
}
