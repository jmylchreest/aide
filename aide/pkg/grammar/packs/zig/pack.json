{
  "schema_version": 1,
  "name": "zig",
  "version": "1.1.2",
  "c_symbol": "tree_sitter_zig",
  "meta": {
    "extensions": [
      ".zig"
    ]
  },
  "complexity": {
    "func_node_types": [
      "FnDecl",
      "TestDecl"
    ],
    "branch_types": [
      "IfExpr",
      "IfStatement",
      "ForStatement",
      "WhileStatement",
      "SwitchExpr"
    ],
    "name_field": "name"
  },
  "tokenisation": {
    "identifier_types": [
      "IDENTIFIER",
      "BUILTINIDENTIFIER"
    ],
    "literal_types": [
      "INTEGER",
      "FLOAT",
      "STRINGLITERAL",
      "CHAR_LITERAL",
      "true",
      "false",
      "null"
    ],
    "keyword_types": [
      "fn",
      "if",
      "else",
      "for",
      "while",
      "switch",
      "return",
      "break",
      "continue",
      "struct",
      "enum",
      "defer",
      "try",
      "catch"
    ]
  },
  "entrypoints": {
    "file_patterns": [
      {
        "file_match": "main.zig",
        "type": "main",
        "label": "Zig main entry point"
      },
      {
        "file_match": "*.zig",
        "content": "pub fn main\\(\\)",
        "type": "main",
        "label": "Zig main function"
      },
      {
        "file_match": "build.zig",
        "type": "build",
        "label": "Zig build script"
      }
    ]
  },
  "notes": "Test blocks (`test \"name\" { ... }`) are tree-sitter detected via TestDecl in the complexity section. No name-based test prefix or framework hook convention applies."
}
