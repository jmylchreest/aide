{
  "schema_version": 1,
  "name": "kotlin",
  "version": "",
  "c_symbol": "tree_sitter_kotlin",
  "source_repo": "tree-sitter-grammars/tree-sitter-kotlin",
  "source_tag": "latest",
  "meta": {
    "extensions": [
      ".kt",
      ".kts"
    ],
    "shebangs": [
      "kotlin"
    ],
    "aliases": [
      "kt"
    ]
  },
  "queries": {
    "tags": "(function_declaration (simple_identifier) @name) @definition.function\n(class_declaration (type_identifier) @name) @definition.class\n(object_declaration (type_identifier) @name) @definition.class"
  },
  "complexity": {
    "func_node_types": [
      "function_declaration"
    ],
    "branch_types": [
      "if_expression",
      "for_statement",
      "while_statement",
      "do_while_statement",
      "when_entry",
      "catch_block",
      "binary_expression",
      "conjunction_expression",
      "disjunction_expression",
      "elvis_expression"
    ],
    "name_field": "simple_identifier"
  },
  "imports": {
    "patterns": [
      {
        "regex": "^\\s*import\\s+([a-zA-Z0-9_.]+)",
        "group": 1
      }
    ]
  },
  "tokenisation": {
    "identifier_types": [
      "simple_identifier"
    ],
    "literal_types": [
      "integer_literal",
      "real_literal",
      "long_literal",
      "character_literal",
      "boolean_literal",
      "line_string_literal",
      "multi_line_string_literal"
    ],
    "keyword_types": [
      "when",
      "val",
      "fun",
      "class",
      "interface",
      "object",
      "if",
      "else",
      "for",
      "while",
      "do",
      "return",
      "break",
      "continue",
      "try",
      "catch",
      "finally",
      "throw",
      "import",
      "package",
      "is",
      "in",
      "as",
      "null",
      "this",
      "super",
      "override",
      "abstract",
      "data",
      "sealed",
      "enum",
      "companion",
      "suspend",
      "async"
    ]
  },
  "entrypoints": {
    "symbols": [
      {
        "name": "main",
        "kind": "function",
        "type": "main",
        "label": "Kotlin main function",
        "exclude": "Test|test"
      }
    ],
    "file_patterns": [
      {
        "file_match": "*.kt",
        "content": "^fun main\\(",
        "type": "main",
        "label": "Kotlin main function"
      },
      {
        "file_match": "*.kt",
        "content": "@SpringBootApplication",
        "type": "server_start",
        "label": "Spring Boot Kotlin application"
      },
      {
        "file_match": "*.kt",
        "content": "embeddedServer\\(",
        "type": "server_start",
        "label": "Ktor embedded server"
      },
      {
        "file_match": "Application.kt",
        "type": "server_start",
        "label": "Ktor/Spring application"
      }
    ]
  },
  "deadcode": {
    "suppression_patterns": [
      "@Suppress\\s*\\([^)]*\\bunused\\b",
      "//\\s*noinspection\\b.*\\bunused\\b",
      "//\\s*aide:keep\\b",
      "@Deprecated\\b"
    ],
    "test_file_patterns": [
      "**/*Test.kt",
      "**/*Tests.kt",
      "**/*Spec.kt",
      "**/src/test/**/*.kt"
    ],
    "framework_hook_names": [
      "setUp",
      "tearDown",
      "beforeAll",
      "afterAll",
      "beforeEach",
      "afterEach",
      "main"
    ]
  }
}
