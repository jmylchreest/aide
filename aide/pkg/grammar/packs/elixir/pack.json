{
  "schema_version": 1,
  "name": "elixir",
  "version": "",
  "c_symbol": "tree_sitter_elixir",
  "source_repo": "elixir-lang/tree-sitter-elixir",
  "source_tag": "latest",
  "meta": {
    "extensions": [
      ".ex",
      ".exs"
    ],
    "shebangs": [
      "elixir"
    ],
    "aliases": [
      "ex",
      "exs"
    ]
  },
  "queries": {
    "tags": "(call target: (identifier) @_def (#match? @_def \"^defp?$\") arguments: (arguments (identifier) @name)) @definition.function\n(call target: (identifier) @_defmodule (#match? @_defmodule \"^defmodule$\") arguments: (arguments (alias) @name)) @definition.module",
    "refs": "(call target: (identifier) @_fn (#match? @_fn \"^(import|alias|use|require)$\") (arguments (alias) @name)) @reference.import"
  },
  "complexity": {
    "func_node_types": [
      "call"
    ],
    "branch_types": [
      "if",
      "unless",
      "cond",
      "case",
      "with",
      "for",
      "binary_operator",
      "stab_clause"
    ],
    "name_field": "target"
  },
  "imports": {
    "patterns": [
      {
        "regex": "^\\s*import\\s+([A-Z][a-zA-Z0-9_.]*)",
        "group": 1
      },
      {
        "regex": "^\\s*alias\\s+([A-Z][a-zA-Z0-9_.]*)",
        "group": 1
      },
      {
        "regex": "^\\s*use\\s+([A-Z][a-zA-Z0-9_.]*)",
        "group": 1
      },
      {
        "regex": "^\\s*require\\s+([A-Z][a-zA-Z0-9_.]*)",
        "group": 1
      }
    ]
  },
  "tokenisation": {
    "identifier_types": [
      "identifier",
      "alias",
      "atom"
    ],
    "literal_types": [
      "string",
      "charlist",
      "integer",
      "float",
      "boolean",
      "nil"
    ],
    "keyword_types": [
      "def",
      "defp",
      "defmodule",
      "defmacro",
      "defstruct",
      "defimpl",
      "defprotocol",
      "fn",
      "do",
      "end",
      "if",
      "else",
      "unless",
      "case",
      "cond",
      "when",
      "with",
      "for",
      "raise",
      "rescue",
      "try",
      "catch",
      "after",
      "receive",
      "import",
      "use",
      "alias",
      "require"
    ]
  },
  "entrypoints": {
    "symbols": [
      {
        "name": "start",
        "kind": "function",
        "type": "init",
        "label": "Elixir OTP application start callback"
      },
      {
        "name": "init",
        "kind": "function",
        "type": "init",
        "label": "Elixir GenServer init callback"
      },
      {
        "name": "main",
        "kind": "function",
        "type": "main",
        "label": "Elixir escript main function"
      }
    ],
    "file_patterns": [
      {
        "file_match": "*.ex",
        "content": "use Application",
        "type": "init",
        "label": "Elixir OTP application module"
      },
      {
        "file_match": "*.ex",
        "content": "use GenServer",
        "type": "init",
        "label": "Elixir GenServer module"
      },
      {
        "file_match": "*.ex",
        "content": "use Phoenix\\.Router",
        "type": "http_handler",
        "label": "Phoenix router"
      },
      {
        "file_match": "mix.exs",
        "type": "build",
        "label": "Elixir Mix project definition"
      },
      {
        "file_match": "router.ex",
        "type": "http_handler",
        "label": "Phoenix router module"
      },
      {
        "file_match": "application.ex",
        "type": "init",
        "label": "Elixir OTP application"
      }
    ]
  },
  "deadcode": {
    "exported_rule": "no_leading_underscore",
    "suppression_patterns": [
      "#\\s*credo:disable-for-next-line\\b",
      "#\\s*aide:keep\\b",
      "@deprecated\\b"
    ],
    "test_file_patterns": [
      "**/test/**/*_test.exs",
      "**/*_test.exs"
    ],
    "framework_hook_names": [
      "setup",
      "setup_all",
      "on_exit"
    ]
  },
  "comments": {
    "line": [
      "#"
    ]
  }
}
