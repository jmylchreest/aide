{
  "schema_version": 1,
  "name": "rust",
  "version": "0.24.0",
  "c_symbol": "tree_sitter_rust",
  "meta": {
    "extensions": [
      ".rs"
    ],
    "aliases": [
      "rs"
    ]
  },
  "queries": {
    "tags": "(function_item name: (identifier) @name) @definition.function\n(impl_item type: (type_identifier) @name) @definition.class\n(struct_item name: (type_identifier) @name) @definition.class\n(enum_item name: (type_identifier) @name) @definition.class\n(trait_item name: (type_identifier) @name) @definition.interface\n(type_item name: (type_identifier) @name) @definition.type\n(mod_item name: (identifier) @name) @definition.module",
    "refs": "(call_expression function: (identifier) @name) @reference.call\n(call_expression function: (field_expression field: (field_identifier) @name)) @reference.call\n(type_identifier) @name @reference.type\n(use_declaration argument: (scoped_identifier) @name) @reference.import\n(use_declaration argument: (identifier) @name) @reference.import"
  },
  "complexity": {
    "func_node_types": [
      "function_item"
    ],
    "branch_types": [
      "if_expression",
      "for_expression",
      "while_expression",
      "loop_expression",
      "match_arm",
      "binary_expression"
    ],
    "name_field": "name"
  },
  "imports": {
    "patterns": [
      {
        "regex": "^\\s*use\\s+(?:crate::)?([a-zA-Z0-9_:]+)",
        "group": 1
      }
    ]
  },
  "tokenisation": {
    "identifier_types": [
      "identifier",
      "type_identifier",
      "field_identifier"
    ],
    "literal_types": [
      "string_literal",
      "integer_literal",
      "float_literal",
      "char_literal",
      "true",
      "false"
    ],
    "keyword_types": [
      "fn",
      "let",
      "if",
      "else",
      "for",
      "while",
      "match",
      "return",
      "break",
      "continue",
      "struct",
      "enum",
      "trait",
      "impl",
      "use",
      "async",
      "await"
    ]
  },
  "entrypoints": {
    "symbols": [
      {
        "name": "main",
        "kind": "function",
        "type": "main",
        "label": "Rust main function",
        "exclude": "test|example"
      }
    ],
    "refs": [
      {
        "name": "run",
        "ref_kind": "call",
        "type": "server_start",
        "label": "Actix/Rocket/Axum server start",
        "qualifier": "HttpServer|Server"
      },
      {
        "name": "bind",
        "ref_kind": "call",
        "type": "server_start",
        "label": "Server socket bind",
        "qualifier": "HttpServer|TcpListener"
      },
      {
        "name": "serve",
        "ref_kind": "call",
        "type": "server_start",
        "label": "Hyper/Tonic server start"
      },
      {
        "name": "add_service",
        "ref_kind": "call",
        "type": "grpc_service",
        "label": "Tonic gRPC service registration"
      },
      {
        "name": "route",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "HTTP route registration",
        "qualifier": "Router|App"
      },
      {
        "name": "command",
        "ref_kind": "call",
        "type": "cli_root",
        "label": "Clap CLI command builder"
      },
      {
        "name": "get_matches",
        "ref_kind": "call",
        "type": "cli_root",
        "label": "Clap CLI parse"
      },
      {
        "name": "parse",
        "ref_kind": "call",
        "type": "cli_root",
        "label": "Clap derive CLI parse"
      }
    ],
    "file_patterns": [
      {
        "file_match": "main.rs",
        "type": "main",
        "label": "Rust main entry point"
      },
      {
        "file_match": "lib.rs",
        "type": "lib_root",
        "label": "Rust library root"
      },
      {
        "file_match": "build.rs",
        "type": "build_script",
        "label": "Rust build script"
      }
    ]
  },
  "security": {
    "rules": [
      {
        "id": "rust-unsafe-block",
        "name": "Unsafe code block",
        "severity": "info",
        "category": "memory",
        "pattern": "\\bunsafe\\s*\\{",
        "description": "Unsafe block bypasses Rust memory safety guarantees. Ensure bounds checks and pointer validity are manually verified."
      },
      {
        "id": "rust-command-injection",
        "name": "Potential command injection",
        "severity": "critical",
        "category": "exec",
        "pattern": "Command::new\\s*\\([^)]*(?:\\+|format!|&)",
        "description": "Shell command with dynamic input. Use explicit argument lists via .arg() and validate all inputs."
      },
      {
        "id": "rust-sql-format",
        "name": "Potential SQL injection via format string",
        "severity": "critical",
        "category": "injection",
        "pattern": "(?:query|execute)\\s*\\(\\s*&?format!\\s*\\(",
        "description": "SQL query built with format!(). Use parameterized queries with $1 placeholders."
      },
      {
        "id": "rust-unwrap-in-production",
        "name": "Use of unwrap() may panic",
        "severity": "info",
        "category": "error-handling",
        "pattern": "\\.unwrap\\(\\)",
        "description": "unwrap() panics on error. Use expect() with a message, or handle errors with ? or match. Panics in production can cause denial of service."
      },
      {
        "id": "rust-raw-pointer-deref",
        "name": "Raw pointer dereference",
        "severity": "warning",
        "category": "memory",
        "pattern": "\\*(?:mut|const)\\s+\\w+",
        "description": "Raw pointer usage. Ensure pointer validity and alignment before dereferencing."
      }
    ]
  },
  "deadcode": {
    "suppression_patterns": [
      "#\\[allow\\(\\s*dead_code\\b",
      "#\\[allow\\(\\s*unused\\b",
      "#\\[deprecated\\b",
      "//\\s*aide:keep\\b",
      "#\\[test\\]",
      "#\\[\\w+::test\\b",
      "#\\[cfg\\s*\\(\\s*test\\b",
      "#\\[bench\\]",
      "#\\[should_panic\\b",
      "#\\[ignore\\b",
      "#\\[test_case\\b",
      "#\\[rstest\\b",
      "#\\[plugin_fn\\b",
      "#\\[no_mangle\\]",
      "#\\[export_name\\b",
      "#\\[wasm_bindgen\\b",
      "#\\[pyfunction\\b"
    ],
    "block_suppression_patterns": [
      "#\\[cfg\\s*\\(\\s*test\\b",
      "#\\[zbus::interface\\b",
      "#\\[zbus::dbus_interface\\b",
      "#\\[interface\\]",
      "#\\[interface\\(",
      "#\\[dbus_interface\\b",
      "#\\[pymethods\\]",
      "#\\[wasm_bindgen\\b"
    ]
  }
}
