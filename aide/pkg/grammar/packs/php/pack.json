{
  "schema_version": 1,
  "name": "php",
  "version": "",
  "c_symbol": "tree_sitter_php",
  "source_repo": "tree-sitter/tree-sitter-php",
  "source_tag": "latest",
  "source_src_dir": "php/src",
  "meta": {
    "extensions": [
      ".php"
    ],
    "shebangs": [
      "php"
    ]
  },
  "queries": {
    "tags": "(function_definition name: (name) @name) @definition.function\n(method_declaration name: (name) @name) @definition.method\n(class_declaration name: (name) @name) @definition.class\n(interface_declaration name: (name) @name) @definition.interface\n(trait_declaration name: (name) @name) @definition.interface",
    "refs": "(function_call_expression function: (name) @name) @reference.call\n(member_call_expression name: (name) @name) @reference.call\n(named_type (name) @name) @reference.type\n(namespace_use_declaration (namespace_use_clause (qualified_name) @name)) @reference.import"
  },
  "complexity": {
    "func_node_types": [
      "function_definition",
      "method_declaration"
    ],
    "branch_types": [
      "if_statement",
      "for_statement",
      "foreach_statement",
      "while_statement",
      "do_statement",
      "switch_case",
      "catch_clause",
      "binary_expression"
    ],
    "name_field": "name"
  },
  "imports": {
    "patterns": [
      {
        "regex": "^\\s*use\\s+([a-zA-Z0-9_\\\\]+)",
        "group": 1
      },
      {
        "regex": "^\\s*(?:require|require_once|include|include_once)\\s+['\"]([^'\"]+)['\"]",
        "group": 1
      }
    ]
  },
  "tokenisation": {
    "identifier_types": [
      "variable_name",
      "name"
    ],
    "literal_types": [
      "encapsed_string",
      "nowdoc_string",
      "heredoc_content"
    ],
    "keyword_types": [
      "trait",
      "function",
      "class",
      "interface",
      "extends",
      "implements",
      "namespace",
      "use",
      "if",
      "else",
      "elseif",
      "for",
      "foreach",
      "while",
      "do",
      "switch",
      "case",
      "break",
      "continue",
      "return",
      "try",
      "catch",
      "finally",
      "throw",
      "new",
      "public",
      "private",
      "protected",
      "static",
      "abstract",
      "final",
      "null",
      "true",
      "false"
    ]
  },
  "entrypoints": {
    "symbols": [
      {
        "name": "handle",
        "kind": "method",
        "type": "http_handler",
        "label": "Laravel controller handle method"
      },
      {
        "name": "boot",
        "kind": "method",
        "type": "init",
        "label": "Laravel service provider boot"
      },
      {
        "name": "register",
        "kind": "method",
        "type": "init",
        "label": "Laravel service provider register"
      }
    ],
    "refs": [
      {
        "name": "get",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "Laravel/Slim GET route",
        "qualifier": "Route|Router"
      },
      {
        "name": "post",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "Laravel/Slim POST route",
        "qualifier": "Route|Router"
      },
      {
        "name": "put",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "Laravel/Slim PUT route",
        "qualifier": "Route|Router"
      },
      {
        "name": "delete",
        "ref_kind": "call",
        "type": "http_handler",
        "label": "Laravel/Slim DELETE route",
        "qualifier": "Route|Router"
      },
      {
        "name": "run",
        "ref_kind": "call",
        "type": "server_start",
        "label": "Slim/Symfony app run"
      },
      {
        "name": "command",
        "ref_kind": "call",
        "type": "cli_command",
        "label": "Laravel Artisan command"
      },
      {
        "name": "addCommand",
        "ref_kind": "call",
        "type": "cli_command",
        "label": "Symfony Console command registration"
      },
      {
        "name": "register",
        "ref_kind": "call",
        "type": "plugin",
        "label": "Service provider registration"
      }
    ],
    "file_patterns": [
      {
        "file_match": "index.php",
        "type": "main",
        "label": "PHP web entry point"
      },
      {
        "file_match": "artisan",
        "type": "cli_root",
        "label": "Laravel Artisan CLI"
      },
      {
        "file_match": "public/index.php",
        "type": "main",
        "label": "Laravel/Symfony web entry point"
      },
      {
        "file_match": "routes/web.php",
        "type": "http_handler",
        "label": "Laravel web routes"
      },
      {
        "file_match": "routes/api.php",
        "type": "http_handler",
        "label": "Laravel API routes"
      },
      {
        "file_match": "*.php",
        "content": "^#!/usr/bin/env php",
        "type": "cli_root",
        "label": "PHP executable script"
      }
    ]
  },
  "security": {
    "rules": [
      {
        "id": "php-sql-injection",
        "name": "Potential SQL injection",
        "severity": "critical",
        "category": "injection",
        "pattern": "(?:mysql_query|mysqli_query|->query)\\s*\\([^)]*(?:\\.\\s*\\$|\\$_(?:GET|POST|REQUEST|COOKIE))",
        "description": "SQL query with user input concatenation. Use prepared statements with PDO or mysqli_prepare."
      },
      {
        "id": "php-xss",
        "name": "Potential XSS via echo/print",
        "severity": "critical",
        "category": "xss",
        "pattern": "(?:echo|print)\\s+[^;]*\\$_(?:GET|POST|REQUEST|COOKIE)",
        "description": "User input echoed without escaping. Use htmlspecialchars() with ENT_QUOTES and UTF-8 encoding."
      },
      {
        "id": "php-eval",
        "name": "Use of eval()",
        "severity": "critical",
        "category": "injection",
        "pattern": "\\beval\\s*\\(",
        "description": "eval() executes arbitrary PHP code. Remove eval usage entirely or use safer alternatives."
      },
      {
        "id": "php-command-injection",
        "name": "Potential command injection",
        "severity": "warning",
        "category": "exec",
        "pattern": "(?:exec|system|passthru|shell_exec|popen|proc_open)\\s*\\(",
        "description": "Shell execution primitive used. Prefer avoiding shell execution entirely, and treat user-controlled command construction as critical."
      },
      {
        "id": "php-file-include",
        "name": "Potential remote file inclusion",
        "severity": "critical",
        "category": "traversal",
        "pattern": "(?:include|require|include_once|require_once)\\s*\\([^)]*\\$_(?:GET|POST|REQUEST)",
        "description": "File include with user input can lead to remote code execution. Never use user input in include paths."
      },
      {
        "id": "php-unserialize",
        "name": "Unsafe deserialization",
        "severity": "critical",
        "category": "deserialize",
        "pattern": "\\bunserialize\\s*\\([^)]*\\$",
        "description": "unserialize() on user input enables arbitrary object injection. Use json_decode() instead."
      },
      {
        "id": "php-weak-hash",
        "name": "Use of weak hash for passwords",
        "severity": "warning",
        "category": "crypto",
        "pattern": "\\b(?:md5|sha1)\\s*\\(",
        "description": "MD5/SHA1 are not suitable for passwords. Use password_hash() with PASSWORD_BCRYPT or PASSWORD_ARGON2ID."
      }
    ]
  }
}
